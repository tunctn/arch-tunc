# Defense-in-depth: never commit key/secret material even if it slips into
# a tracked path by mistake. Basename patterns match at any depth.
*.key
*.pem
*_rsa
*_dsa
*_ecdsa
*_ed25519
id_*
*.gpg
*.kdbx
.env
.env.*
.netrc
*.token
*credentials*

# Sunshine: web-UI login hash + paired-client certs. Not in the allowlist,
# but *.pem/*credentials* wouldn't catch this one if it ever got added.
sunshine_state.json
sunshine.log
