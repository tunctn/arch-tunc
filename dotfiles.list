# Allowlist of paths to sync, relative to $HOME. One per line.
# Only what's listed here is copied into the repo and pushed to GitHub.
# Lines starting with # are ignored. Missing paths are skipped silently.
#
# SAFETY: never add anything containing secrets/sessions here, e.g.
#   .ssh  .config/1Password  .config/op  .config/BraveSoftware
#   .config/google-chrome*  .config/chromium  .config/vivaldi*
#   .mozilla  .config/pulse  .config/session  .netrc  .env

# --- shell ---
.bashrc
.bash_profile
.profile
.gitconfig
.inputrc

# --- hyprland desktop ---
.config/hypr
.config/kitty

# --- wallpapers (binary images; kept so wpaperd works after a restore) ---
Pictures/wallpapers

# --- kde/misc ---
.config/dolphinrc
.config/mimeapps.list
.config/autostart

# --- extras (auto-synced whenever these get created; skipped until then) ---
.config/nvim
.config/waybar
.config/wofi
.config/rofi
.config/dunst
.config/mako
.config/swaync
.config/wlogout
.config/swaylock
.config/wpaperd
.config/starship.toml
.config/gtk-3.0/settings.ini
.config/gtk-4.0/settings.ini
.zshrc
.bash_aliases

# --- sunshine (moonlight game-stream host; reached over tailscale) ---
# Listed FILE-BY-FILE on purpose — do NOT change these to `.config/sunshine`,
# that would sweep in the secrets below.
# NOT listed on purpose:
#   .config/sunshine/credentials/     -> web-UI TLS CA + private key (cakey.pem)
#   .config/sunshine/sunshine_state.json -> web-UI login salt+password hash and
#                                        the certs of every paired client
#   .config/sunshine/sunshine.log     -> noise, regenerated on every run
# After a restore: re-pair clients and re-set the web-UI login at
# https://<tailscale-ip>:47990 — that state is intentionally not portable.
.config/sunshine/sunshine.conf
.config/sunshine/apps.json

# --- systemd user units (sunshine autostart + this repo's own sync timer) ---
# Includes the *.wants/ enablement symlinks, so services come back enabled.
.config/systemd/user

# --- claude code (config + chat history ONLY; secrets deliberately excluded) ---
# NOT listed on purpose: .claude/.credentials.json (OAuth token),
# .claude/sessions, .claude/session-env, .claude/shell-snapshots (env/secrets),
# .claude/cache, .claude/downloads, .claude/backups, .claude/file-history,
# .claude/plugins (noise/bloat).
.claude.json
.claude/settings.json
.claude/history.jsonl
.claude/projects
.claude/commands
.claude/agents
.claude/CLAUDE.md
.claude/memory
