# Allowlist of paths to sync, relative to $HOME. One per line.
# Only what's listed here is copied into the repo and pushed to GitHub.
# Lines starting with # are ignored. Missing paths are skipped silently.
#
# SAFETY: never add anything containing secrets/sessions here, e.g.
#   .ssh  .config/1Password  .config/op  .config/BraveSoftware
#   .config/google-chrome*  .config/chromium  .config/vivaldi*
#   .mozilla  .config/pulse  .config/session  .netrc  .env

# --- shell ---
.bashrc
.bash_profile
.profile
.gitconfig
.inputrc

# --- hyprland desktop ---
.config/hypr
.config/kitty

# --- kde/misc ---
.config/dolphinrc
.config/mimeapps.list
.config/autostart

# --- extras (auto-synced whenever these get created; skipped until then) ---
.config/nvim
.config/waybar
.config/wofi
.config/rofi
.config/dunst
.config/mako
.config/swaync
.config/wlogout
.config/swaylock
.config/starship.toml
.config/gtk-3.0/settings.ini
.config/gtk-4.0/settings.ini
.zshrc
.bash_aliases
